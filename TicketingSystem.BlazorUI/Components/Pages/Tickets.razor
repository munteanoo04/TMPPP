@page "/tickets"
@inject HttpClient Http

<PageTitle>Active Tickets - TicketCore</PageTitle>

<div class="header d-flex justify-content-between align-items-center mb-5">
    <div>
        <h1 class="mb-2">Support Dashboard</h1>
        <p class="text-muted">Real-time overview of system issues and resolutions.</p>
    </div>
    <a href="create-ticket" class="btn-premium">
        <i class="bi bi-plus-lg"></i> CREATE NEW TICKET
    </a>
</div>

<div class="stat-grid">
    <div class="glass-card stat-card">
        <span class="text-muted small font-weight-bold">OPEN TICKETS</span>
        <div class="stat-value text-accent">@tickets?.Count(t => t.Status == TicketStatus.Open)</div>
    </div>
    <div class="glass-card stat-card">
        <span class="text-muted small font-weight-bold">IN PROGRESS</span>
        <div class="stat-value text-warning">@tickets?.Count(t => t.Status == TicketStatus.InProgress)</div>
    </div>
    <div class="glass-card stat-card">
        <span class="text-muted small font-weight-bold">RESOLVED TODAY</span>
        <div class="stat-value text-success">@tickets?.Count(t => t.Status == TicketStatus.Resolved)</div>
    </div>
    <div class="glass-card stat-card">
        <span class="text-muted small font-weight-bold">URGENT</span>
        <div class="stat-value text-danger">@tickets?.Count(t => t.Priority == TicketPriority.Urgent)</div>
    </div>
</div>

<div class="ticket-list">
    <h3 class="mb-4">Recent Activity</h3>
    @if (tickets == null)
    {
        <div class="glass-card text-center py-5">
            <div class="spinner-border text-primary mb-3"></div>
            <p>Synchronizing with support database...</p>
        </div>
    }
    else if (!tickets.Any())
    {
        <div class="glass-card text-center py-5">
            <i class="bi bi-inbox fs-1 text-muted mb-3"></i>
            <p>Inbox zero! All tickets are currently resolved.</p>
        </div>
    }
    else
    {
        @foreach (var ticket in tickets)
        {
            <div class="glass-card ticket-item">
                <div>
                    <h4 class="mb-2">@ticket.Title</h4>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small"><i class="bi bi-person"></i> @ticket.CreatedBy</span>
                        <span class="text-muted small"><i class="bi bi-clock"></i> @ticket.CreatedAt.ToShortDateString()</span>
                    </div>
                </div>
                <div>
                    <span class="ticket-status @GetStatusClass(ticket.Status)">@ticket.Status</span>
                </div>
                <div>
                    <span class="badge @GetPriorityClass(ticket.Priority)">@ticket.Priority</span>
                </div>
                <div>
                    <button class="btn btn-link text-accent p-0"><i class="bi bi-arrow-right-circle fs-4"></i></button>
                </div>
            </div>
        }
    }
</div>

<style>
    .badge-urgent { background: rgba(239, 68, 68, 0.2); color: var(--danger); border: 1px solid var(--danger); }
    .badge-high { background: rgba(245, 158, 11, 0.2); color: var(--warning); border: 1px solid var(--warning); }
    .badge-medium { background: rgba(99, 102, 241, 0.2); color: var(--primary); border: 1px solid var(--primary); }
    .badge-low { background: rgba(148, 163, 184, 0.2); color: var(--text-muted); border: 1px solid var(--text-muted); }
    
    .badge {
        padding: 0.25rem 0.5rem;
        border-radius: 4px;
        font-size: 0.7rem;
        font-weight: bold;
    }
</style>

@code {
    private IEnumerable<TicketDto>? tickets;

    protected override async Task OnInitializedAsync()
    {
        try {
            tickets = await Http.GetFromJsonAsync<IEnumerable<TicketDto>>("api/tickets");
        } catch {
            // Demo data if API is not running
            tickets = new List<TicketDto> {
                new TicketDto(Guid.NewGuid(), "Fix login issue", "Users cannot login with Gmail", TicketStatus.Open, TicketPriority.Urgent, "John Doe", null, DateTime.Now),
                new TicketDto(Guid.NewGuid(), "Update CSS", "Button colors are wrong", TicketStatus.InProgress, TicketPriority.Medium, "Alice Smith", "Bob UI", DateTime.Now.AddDays(-1)),
                new TicketDto(Guid.NewGuid(), "Database migration", "Add new fields to User", TicketStatus.Resolved, TicketPriority.High, "Charlie", "David", DateTime.Now.AddDays(-2))
            };
        }
    }

    private string GetStatusClass(TicketStatus status) => status switch
    {
        TicketStatus.Open => "status-open",
        TicketStatus.InProgress => "status-inprogress",
        TicketStatus.Resolved => "status-resolved",
        TicketStatus.Closed => "status-closed",
        _ => ""
    };

    private string GetPriorityClass(TicketPriority priority) => priority switch
    {
        TicketPriority.Urgent => "badge-urgent",
        TicketPriority.High => "badge-high",
        TicketPriority.Medium => "badge-medium",
        TicketPriority.Low => "badge-low",
        _ => ""
    };
}
