@page "/"
@inject HttpClient Http

<PageTitle>Dashboard - TicketCore</PageTitle>

<div class="header mb-4">
    <h1>System Dashboard</h1>
    <p class="text-muted">Overview of current ticket status and performance.</p>
</div>

<div class="stat-grid">
    <div class="glass-card stat-card">
        <span class="text-muted">Total Tickets</span>
        <span class="stat-value">@totalTickets</span>
    </div>
    <div class="glass-card stat-card">
        <span class="text-muted text-accent">Open</span>
        <span class="stat-value">@openTickets</span>
    </div>
    <div class="glass-card stat-card">
        <span class="text-muted text-warning">In Progress</span>
        <span class="stat-value">@inProgressTickets</span>
    </div>
    <div class="glass-card stat-card">
        <span class="text-muted text-success">Resolved</span>
        <span class="stat-value">@resolvedTickets</span>
    </div>
</div>

<div class="glass-card">
    <h3 class="mb-4">Quick Insights</h3>
    <p>Architecture applied: <strong>Clean Architecture</strong></p>
    <ul>
        <li><strong>SRP:</strong> Handlers managed via MediatR.</li>
        <li><strong>OCP:</strong> Extensible data access via IRepository.</li>
        <li><strong>DIP:</strong> Abstractions defined in Domain, implemented in Infrastructure.</li>
    </ul>
</div>

@code {
    private int totalTickets = 0;
    private int openTickets = 0;
    private int inProgressTickets = 0;
    private int resolvedTickets = 0;

    protected override async Task OnInitializedAsync()
    {
        try {
            var tickets = await Http.GetFromJsonAsync<IEnumerable<TicketDto>>("api/tickets");
            if (tickets != null) {
                totalTickets = tickets.Count();
                openTickets = tickets.Count(t => t.Status == TicketStatus.Open);
                inProgressTickets = tickets.Count(t => t.Status == TicketStatus.InProgress);
                resolvedTickets = tickets.Count(t => t.Status == TicketStatus.Resolved);
            }
        } catch {
            // Handle error or use mocked data for demo
            totalTickets = 12;
            openTickets = 5;
            inProgressTickets = 3;
            resolvedTickets = 4;
        }
    }
}
