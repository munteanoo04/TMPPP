@page "/create-ticket"
@inject HttpClient Http
@inject NavigationManager Nav

<PageTitle>New Ticket - TicketCore</PageTitle>

<div class="header mb-4">
    <h1>Create New Ticket</h1>
    <p class="text-muted">Fill in the details to submit a new system ticket.</p>
</div>

<div class="glass-card" style="max-width: 600px;">
    <EditForm Model="ticketModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Title</label>
            <InputText @bind-Value="ticketModel.Title" class="input-premium" placeholder="Brief summary of the issue" />
            <ValidationMessage For="@(() => ticketModel.Title)" />
        </div>

        <div class="mb-3">
            <label class="form-label text-muted small uppercase">Description</label>
            <InputTextArea @bind-Value="ticketModel.Description" class="input-premium" rows="4" placeholder="Detailed explanation" />
            <ValidationMessage For="@(() => ticketModel.Description)" />
        </div>

        <div class="row mb-4">
            <div class="col-md-6">
                <label class="form-label text-muted small uppercase">Priority</label>
                <InputSelect @bind-Value="ticketModel.Priority" class="input-premium">
                    @foreach (var p in Enum.GetValues<TicketPriority>())
                    {
                        <option value="@p">@p</option>
                    }
                </InputSelect>
            </div>
            <div class="col-md-6">
                <label class="form-label text-muted small uppercase">Your Name</label>
                <InputText @bind-Value="ticketModel.CreatedBy" class="input-premium" placeholder="Username" />
            </div>
        </div>

        <div class="d-flex gap-3">
            <button type="submit" class="btn-premium">Submit Ticket</button>
            <button type="button" class="btn btn-outline-secondary" @onclick='() => Nav.NavigateTo("tickets")'>Cancel</button>
        </div>
    </EditForm>
</div>

@code {
    private CreateTicketDto ticketModel = new("", "", TicketPriority.Medium, "Current User");

    private async Task HandleSubmit()
    {
        try {
            var response = await Http.PostAsJsonAsync("api/tickets", ticketModel);
            if (response.IsSuccessStatusCode)
            {
                Nav.NavigateTo("tickets");
            }
        } catch {
            // Success navigation for demo
            Nav.NavigateTo("tickets");
        }
    }
}
